[adapters]
llm = "claude"
messaging = "log"   # replace with "whatsapp" once the adapter is implemented
storage = "json"    # replace with "postgres" for production persistence

[json_storage]
path = "/var/data/manager-ai/conversations"

[claude]
model = "claude-sonnet-4-6"
api_key_env = "ANTHROPIC_API_KEY"
